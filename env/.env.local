# This file includes environment variables that will be committed to git by default.

# Built-in environment variables
TEAMSFX_ENV=local
APP_NAME_SUFFIX=local

# MCP Server (set after starting devtunnel)
MCP_SERVER_URL=https://<your-tunnel-id>-3001.inc1.devtunnels.ms
MCP_SERVER_DOMAIN=<your-tunnel-id>-3001.inc1.devtunnels.ms

# Entra tenant
ENTRA_TENANT_ID=<your-tenant-id>

# OAuth (populated by oauth/register during provision — leave empty to force fresh registration)
AGENT365_MCP_AUTH_ID=

# M365 (populated by extendToM365 during provision)
M365_TITLE_ID=
M365_APP_ID=

# Agent scope
AGENT_SCOPE=personal

TEAMS_APP_ID=
TEAMS_APP_TENANT_ID=
SHARE_LINK=