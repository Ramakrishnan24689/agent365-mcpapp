# Secrets for ATK provisioning — NEVER commit this file
# Copy this file to env/.env.local.user and fill in your values

# Entra app registration (same app as .env — used by ATK for OAuth registration)
AGENT365_MCP_CLIENT_ID=<your-entra-app-client-id>
AGENT365_MCP_CLIENT_SECRET=<your-entra-app-client-secret>
