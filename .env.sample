# Server runtime environment variables
# Copy this file to .env and fill in your values

# Port for the MCP server
PORT=3001

# Set to "false" for live Graph API calls, "true" for mock data
USE_MOCK_DATA=true

# Entra ID app registration credentials (same app used for OBO)
ENTRA_CLIENT_ID=<your-entra-app-client-id>
ENTRA_CLIENT_SECRET=<your-entra-app-client-secret>
ENTRA_TENANT_ID=<your-tenant-id>
