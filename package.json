{
  "name": "agent365-mcpapp",
  "version": "1.0.0",
  "type": "module",
  "private": false,
  "description": "Agent 365 MCP App — Surface Microsoft Agent 365 governance capabilities (registry, map, risk) inside M365 Copilot Chat with interactive Fluent UI widgets and authenticated Microsoft Graph API calls via OBO flow.",
  "author": "Ramakrishnan Raman",
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-apps",
    "microsoft-365",
    "copilot",
    "declarative-agent",
    "microsoft-graph",
    "agent-365",
    "fluent-ui",
    "obo",
    "oauth"
  ],
  "scripts": {
    "build": "tsc --noEmit && node build-ui.mjs && tsc -p tsconfig.server.json",
    "serve": "tsx main.ts",
    "start": "npm run build && npm run serve",
    "dev": "cross-env NODE_ENV=development concurrently \"node build-ui.mjs --watch\" \"tsx watch main.ts\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector http://localhost:3001/mcp"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.0",
    "@fluentui/react-components": "^9.56.0",
    "@fluentui/react-icons": "^2.0.0",
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "@types/d3": "^7.4.3",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
