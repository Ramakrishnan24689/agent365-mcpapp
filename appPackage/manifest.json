{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.26/MicrosoftTeams.schema.json",
    "manifestVersion": "1.26",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Ramakrishnan Raman",
        "websiteUrl": "https://www.example.com",
        "privacyUrl": "https://www.example.com/privacy",
        "termsOfUseUrl": "https://www.example.com/termofuse"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Agent 365${{APP_NAME_SUFFIX}}",
        "full": "Agent 365 — AI Agent Management for M365 Copilot"
    },
    "description": {
        "short": "Manage and monitor AI agents in your Microsoft 365 environment",
        "full": "Agent 365 surfaces the full Agent 365 admin experience inside M365 Copilot. View the agent registry, visualize the agent map, monitor risky agents, and take admin actions like blocking or reassigning agents — all from within Copilot Chat."
    },
    "accentColor": "#0078D4",
    "supportsChannelFeatures": "tier1",
    "composeExtensions": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "validDomains": [
        "${{MCP_SERVER_DOMAIN}}"
    ],
    "webApplicationInfo": {
        "id": "${{AGENT365_MCP_CLIENT_ID}}",
        "resource": "api://${{AGENT365_MCP_CLIENT_ID}}"
    }
}
