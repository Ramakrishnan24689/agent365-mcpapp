{
    "$schema": "https://developer.microsoft.com/json-schemas/copilot/plugin/v2.4/schema.json",
    "schema_version": "v2.4",
    "name_for_human": "Agent 365",
    "description_for_human": "Manage and monitor AI agents in your Microsoft 365 organization",
    "contact_email": "admin@contoso.com",
    "namespace": "agent365",
    "functions": [
        {
            "name": "show_agent_registry",
            "description": "Show the full Agent 365 registry with all agents, their status, platform, risk level, and ownership. Provides an interactive inventory with filters, search, and detail drawer."
        },
        {
            "name": "show_agent_map",
            "description": "Visualize all agents as an interactive circle-packing bubble map, grouped by publisher type."
        },
        {
            "name": "show_risky_agents",
            "description": "Show agents with active risk signals from identity protection. Displays severity levels and threat details."
        },
        {
            "name": "block_agent",
            "description": "Block a specific agent by ID, preventing it from being used."
        },
        {
            "name": "unblock_agent",
            "description": "Unblock a previously blocked agent, restoring it to active status."
        },
        {
            "name": "reassign_agent",
            "description": "Reassign ownership of an agent to a different user."
        },
        {
            "name": "search_users",
            "description": "Search for users in the organization by name or email to find a new owner."
        },
        {
            "name": "load_agent_info",
            "description": "Fetch detailed information for a single agent including instructions, knowledge sources, and actions."
        }
    ],
    "runtimes": [
        {
            "type": "RemoteMCPServer",
            "spec": {
                "url": "${{MCP_SERVER_URL}}/mcp",
                "mcp_tool_description": {
                    "tools": [
                        {
                            "name": "show_agent_registry",
                            "title": "Agent Registry",
                            "description": "Show the full Agent 365 registry with all agents, their status, platform, risk level, and ownership.",
                            "inputSchema": {
                                "type": "object",
                                "properties": {},
                                "$schema": "http://json-schema.org/draft-07/schema#"
                            },
                            "annotations": { "readOnlyHint": true },
                            "_meta": {
                                "ui": { "resourceUri": "ui://show_agent_registry/agent-registry.html" },
                                "ui/resourceUri": "ui://show_agent_registry/agent-registry.html"
                            }
                        },
                        {
                            "name": "show_agent_map",
                            "title": "Agent Map",
                            "description": "Visualize all agents as an interactive circle-packing bubble map grouped by publisher type.",
                            "inputSchema": {
                                "type": "object",
                                "properties": {},
                                "$schema": "http://json-schema.org/draft-07/schema#"
                            },
                            "annotations": { "readOnlyHint": true },
                            "_meta": {
                                "ui": { "resourceUri": "ui://show_agent_map/agent-map.html" },
                                "ui/resourceUri": "ui://show_agent_map/agent-map.html"
                            }
                        },
                        {
                            "name": "show_risky_agents",
                            "title": "Risky Agents",
                            "description": "Show agents with active risk signals from identity protection.",
                            "inputSchema": {
                                "type": "object",
                                "properties": {},
                                "$schema": "http://json-schema.org/draft-07/schema#"
                            },
                            "annotations": { "readOnlyHint": true },
                            "_meta": {
                                "ui": { "resourceUri": "ui://show_risky_agents/risky-agents.html" },
                                "ui/resourceUri": "ui://show_risky_agents/risky-agents.html"
                            }
                        },
                        {
                            "name": "block_agent",
                            "title": "Block Agent",
                            "description": "Block a specific agent by ID.",
                            "inputSchema": {
                                "type": "object",
                                "properties": {
                                    "agentId": { "type": "string", "description": "The ID of the agent to block" },
                                    "reason": { "type": "string", "description": "Reason for blocking" }
                                },
                                "required": ["agentId"],
                                "$schema": "http://json-schema.org/draft-07/schema#"
                            },
                            "annotations": { "readOnlyHint": false }
                        },
                        {
                            "name": "unblock_agent",
                            "title": "Unblock Agent",
                            "description": "Unblock a previously blocked agent.",
                            "inputSchema": {
                                "type": "object",
                                "properties": {
                                    "agentId": { "type": "string", "description": "The ID of the agent to unblock" }
                                },
                                "required": ["agentId"],
                                "$schema": "http://json-schema.org/draft-07/schema#"
                            },
                            "annotations": { "readOnlyHint": false }
                        },
                        {
                            "name": "reassign_agent",
                            "title": "Reassign Agent Owner",
                            "description": "Reassign ownership of an agent to a different user.",
                            "inputSchema": {
                                "type": "object",
                                "properties": {
                                    "agentId": { "type": "string", "description": "The ID of the agent to reassign" },
                                    "newOwnerId": { "type": "string", "description": "The user ID of the new owner" }
                                },
                                "required": ["agentId", "newOwnerId"],
                                "$schema": "http://json-schema.org/draft-07/schema#"
                            },
                            "annotations": { "readOnlyHint": false }
                        },
                        {
                            "name": "search_users",
                            "title": "Search Users",
                            "description": "Search for users in the organization by name or email.",
                            "inputSchema": {
                                "type": "object",
                                "properties": {
                                    "query": { "type": "string", "description": "Search query — user name or email prefix" }
                                },
                                "required": ["query"],
                                "$schema": "http://json-schema.org/draft-07/schema#"
                            },
                            "annotations": { "readOnlyHint": true }
                        },
                        {
                            "name": "load_agent_info",
                            "title": "Load Agent Info",
                            "description": "Fetch detailed information for a single agent including instructions, knowledge sources, and actions.",
                            "inputSchema": {
                                "type": "object",
                                "properties": {
                                    "agentId": { "type": "string", "description": "The package ID of the agent" }
                                },
                                "required": ["agentId"],
                                "$schema": "http://json-schema.org/draft-07/schema#"
                            },
                            "annotations": { "readOnlyHint": true }
                        }
                    ]
                }
            },
            "run_for_functions": [
                "show_agent_registry",
                "show_agent_map",
                "show_risky_agents",
                "block_agent",
                "unblock_agent",
                "reassign_agent",
                "search_users",
                "load_agent_info"
            ],
            "auth": {
                "type": "OAuthPluginVault",
                "reference_id": "${{AGENT365_MCP_AUTH_ID}}"
            }
        }
    ]
}
